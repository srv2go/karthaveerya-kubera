# Only used when LLM_PROVIDER=openai_compat
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=claude-opus-4-5-20251101

# Market data
DATA_SOURCE=alpaca
ALPACA_KEY_ID=changeme
ALPACA_SECRET=changeme

# Paths
ALPHATRADER_DB_PATH=alphatrader.db
ALPHATRADER_RISK_CONFIG=config/risk.yaml
ALPHATRADER_SYMBOLS_CONFIG=config/symbols.yaml
